# ---- gRPC ----
GRPC_URL=0.0.0.0:50051

# ---- Postgres ----
DATABASE_URL=postgresql://ezrah:ezrah@localhost:5432/ezrah?schema=public

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ezrah-credential-pipeline
# Unique per running node. Used for the per-node event-fanout consumer group.
APP_INSTANCE_ID=node-1
# Partitions created for each step topic. More partitions => more per-request parallelism.
STEP_TOPIC_PARTITIONS=6

# ---- Pipeline simulation ----
# Probability [0..1] that identity verification / signing fails transiently.
IDENTITY_FAILURE_RATE=0.25
SIGNING_FAILURE_RATE=0.25
IDENTITY_DELAY_MS=400
SIGNING_DELAY_MS=600

# ---- Retry / resilience ----
MAX_STEP_ATTEMPTS=4
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=15000

# ---- Outbox relay ----
OUTBOX_POLL_INTERVAL_MS=400
OUTBOX_BATCH_SIZE=100
# Lease window when a relay claims a batch (must exceed a batch's publish time).
OUTBOX_CLAIM_LEASE_MS=30000

# ---- Callback delivery ----
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_TIMEOUT_MS=5000
